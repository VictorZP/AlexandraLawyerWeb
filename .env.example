# Публичный сайт (по умолчанию, если не задано)
# VITE_SITE_MODE=public

# Отдельный деплой только для /admin: редирект с / на /admin, контент из localStorage после сохранения
# VITE_SITE_MODE=admin

# Локально без vercel dev: вход в админку по паролю из .env (только dev, не для продакшена)
# VITE_DEV_ADMIN_BYPASS=1
# VITE_DEV_ADMIN_PASSWORD=your-local-secret

# На Vercel (Serverless, не VITE_): пароль входа и секрет подписи сессии
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
